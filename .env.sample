# Copy to .env and fill in real values. .env is gitignored.
# Sourced by scripts/smoke-test.sh.

# Credentials for the authenticated portion of the smoke test.
# Leave blank to run public-endpoint checks only.
SMOKE_EMAIL=system@memoryvault.local
SMOKE_PASSWORD=

# Encryption key for backup provider credentials (AES-256-GCM).
# Generate with: openssl rand -hex 16
MEMORYVAULT_ENCRYPTION_KEY=
